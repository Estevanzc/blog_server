### User membering
GET {{baseUrl}}/membering/1

### Member requests
GET {{baseUrl}}/requests/1
Authorization: Bearer {{token}}

### Get notifications
GET {{baseUrl}}/notifications/1
Authorization: Bearer {{token}}

### Delete notification
DELETE {{baseUrl}}/notifications/destroy/1
Authorization: Bearer {{token}}

### Delete all notifications
DELETE {{baseUrl}}/notifications/destroy/all
Authorization: Bearer {{token}}

### User posts
GET {{baseUrl}}/posts/1

### Store preferences
POST {{baseUrl}}/preferences/store
Authorization: Bearer {{token}}
Content-Type: {{json}}

{
  "dark_mode": true
}

### User searches
GET {{baseUrl}}/searches
Authorization: Bearer {{token}}

### Delete search
DELETE {{baseUrl}}/searches/destroy/1
Authorization: Bearer {{token}}

### Update user
PUT {{baseUrl}}/update
Authorization: Bearer {{token}}
Content-Type: {{json}}

{
  "name": "Updated Name"
}

### Delete user
DELETE {{baseUrl}}/1
Authorization: Bearer {{token}}
